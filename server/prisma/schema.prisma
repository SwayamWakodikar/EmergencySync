generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model ambulance{
  id Int @id @default(autoincrement())
  lat Float
  lng Float 
  status String
  updatedAt DateTime @updatedAt

}
model Emergencyu{
  id Int @id @default(autoincrement())
  lat Float
  lng Float
  severity String
  status String
  createdAt DateTime @default(now())
}
model Assignment {
  id Int @id @default(autoincrement())
  ambulanceId String
  emergencyId String
  assignedAt DateTime @default(now())
}
